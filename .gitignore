__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
.venv-broken-uv/
node_modules/

evals/reports/*
!evals/reports/.gitkeep

# Agent-local state (session files, per-user settings, not project config)
# .codex/ is intentionally NOT listed here because .codex/environments/ is tracked project config
# .claude/ is ignored except the shared, version-controlled launchers re-included below.
# Local-only state (settings.local.json, sessions, caches) stays ignored.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/settings.json
.cursor/
.worktrees/

# Local environment - contains API keys, never commit
.env

# Rehearsal session state - contains host credentials, never commit
.rehearsal/
