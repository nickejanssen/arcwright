{
  "name": "@arcwright/nightcap-web",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "typecheck": "node ../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node ../node_modules/typescript/bin/tsc -p tsconfig.renderers.json",
    "build": "node ../node_modules/typescript/bin/tsc -p tsconfig.json && npm run bundle:mini-games",
    "bundle:mini-games": "node scripts/discover-mini-games.mjs",
    "test": "npm run build && node --import ./tests/register-cloudflare-workers-loader.mjs --test dist/tests/index.test.js"
  }
}
